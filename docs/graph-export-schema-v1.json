{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sre0089/sherpa/blob/main/docs/graph-export-schema-v1.json",
  "title": "Sherpa graph export",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generator", "repository", "counts", "nodes", "edges"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {
          "const": "sherpa"
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root"],
      "properties": {
        "root": {
          "const": "."
        }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": {
          "type": "integer",
          "minimum": 0
        },
        "edges": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    }
  },
  "$defs": {
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line", "column", "byte"],
      "properties": {
        "line": {
          "type": "integer",
          "minimum": 0
        },
        "column": {
          "type": "integer",
          "minimum": 0
        },
        "byte": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {
          "$ref": "#/$defs/position"
        },
        "end": {
          "$ref": "#/$defs/position"
        }
      }
    },
    "symbol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name", "qualified_name", "signature", "file", "range"],
      "properties": {
        "kind": {
          "enum": ["function", "method", "class", "struct"]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "qualified_name": {
          "type": "string",
          "minLength": 1
        },
        "signature": {
          "type": "string"
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "range": {
          "$ref": "#/$defs/range"
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "file"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": ["file", "symbol"]
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "const": "definition"
        },
        "symbol": {
          "$ref": "#/$defs/symbol"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "symbol"
              }
            }
          },
          "then": {
            "required": ["role", "symbol"]
          },
          "else": {
            "not": {
              "anyOf": [
                {
                  "required": ["role"]
                },
                {
                  "required": ["symbol"]
                }
              ]
            }
          }
        }
      ]
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node", "reason", "rank"],
      "properties": {
        "node": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "rank": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "source",
        "target",
        "target_text",
        "resolution",
        "confidence",
        "provenance",
        "evidence",
        "candidates"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": ["defines", "calls", "includes"]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": ["string", "null"]
        },
        "target_text": {
          "type": "string"
        },
        "resolution": {
          "enum": ["resolved", "ambiguous", "unresolved"]
        },
        "confidence": {
          "enum": ["high", "medium", "low"]
        },
        "provenance": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "$ref": "#/$defs/range"
        },
        "candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/candidate"
          }
        }
      }
    }
  }
}
